    "{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How is this different from the Leadpages I know?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We rebuilt the product from the ground up. Same team, same 13-year track record. New technology. A/B testing, Smart Traffic, heatmaps, and AI page creation are all new. A/B testing starts at $99. Smart Traffic and heatmaps from $199.\"}},{\"@type\":\"Question\",\"name\":\"What happens to my existing pages?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nothing changes unless you want it to. Your pages keep working. Choose old or new experience any time. Your price stays the same.\"}},{\"@type\":\"Question\",\"name\":\"How does Smart Traffic work?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Smart Traffic routes each visitor to the page variant most likely to convert them, based on traffic source, device, and past performance data. It runs automatically.\"}},{\"@type\":\"Question\",\"name\":\"Can I use my own domain?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Custom domains with free SSL on every paid plan. Automated DNS setup. 1.8-second median load time on a global CDN. Unlimited traffic.\"}},{\"@type\":\"Question\",\"name\":\"What integrations do you support?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"HubSpot, Salesforce, Mailchimp, Google Ads, Stripe, Shopify, Slack, Zapier, and many more via Paragon. Leads flow directly to your CRM or email tool.\"}},{\"@type\":\"Question\",\"name\":\"Is there a free trial?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. 7 days, full platform access.\"}}]}"
