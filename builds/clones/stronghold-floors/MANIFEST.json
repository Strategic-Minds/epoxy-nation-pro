  "schema_data": [
    "{\n  \"@context\": \"http://schema.org\",\n  \"@type\": \"VideoObject\",\n  \"name\": \"Stronghold Floors - Professional Concrete Coatings in MD PA VA &amp; WVYour Video Title\",\n  \"description\": \"&lt;span&gt;Are you tired of your dirty, cracked garage floor? Stronghold Floors transforms dull concrete into a beautiful, durable, and easy-to-clean space. This video shows how our professional team installs a high-quality garage floor coating, turning your garage into a functional and polished extension of your home. With over 9,000 floors installed and more than 1,000 five-star reviews, we&#39;re committed to quality, durability, and a smooth process from start to finish. Our coatings are installed to last, giving you a garage floor that stands up to spills, heavy use, and years of wear and tear. Serving homeowners in greater Maryland, central and southeastern Pennsylvania, northern Virginia, and the eastern panhandle of West Virginia. &lt;/span&gt;\",\n  \"thumbnailUrl\": \"https://i.ytimg.com/vi/P70IVEJWSSE/default.jpg\",\n  \"uploadDate\": \"2025-09-08T09:00:00Z\",\n  \"duration\": \"PT1M32S\",\n  \"embedUrl\": \"https://www.youtube.com/embed/P70IVEJWSSE\"\n}"
